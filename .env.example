# Where the test app talks to. Defaults to live prod.
VITE_API_BASE=https://api.abugida.et

# Web OAuth client ID — paste the same value used as GOOGLE_CLIENT_ID on the
# backend. Required only for the ID-token flow (section 2). Without it, the
# Google button section shows a clear "not set" error; everything else still
# works.
VITE_GOOGLE_CLIENT_ID=

# Where the legacy redirect flow lands after Google. Origin must be in the
# API's TRUSTED_ORIGINS or be a loopback. Only used for section 3.
VITE_GOOGLE_CALLBACK_URL=http://localhost:3001/?google=success
